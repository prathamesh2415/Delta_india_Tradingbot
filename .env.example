# Delta Exchange India - https://www.delta.exchange/app/account/manageapikeys
DELTA_API_KEY=your_api_key_here
DELTA_API_SECRET=your_api_secret_here

TRADING_SYMBOL=BTCUSD
TIMEFRAME=15m
# Optional: only used if live balance API fails (do not use for normal trading)
# ACCOUNT_EQUITY_USD=100
PAPER_TRADING=true

RISK_PER_TRADE_PERCENT=1
TARGET_RR=2.0
EMA_LENGTH=5
SIGNAL_WINDOW_BARS=3
MAX_DAILY_LOSS_PERCENT=5
MAX_DAILY_TRADES=5

DATABASE_PATH=trading_data.db
LOG_LEVEL=INFO
LOG_FILE=logs/trading.log

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# London-NY session (UTC hours, inclusive start, exclusive end)
SESSION_START_UTC_HOUR=13
SESSION_END_UTC_HOUR=21

SERVER_HOST=127.0.0.1
SERVER_PORT=8000
DASHBOARD_PASSWORD=change_me
TAKER_FEE_PERCENT=0.05
